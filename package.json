{
  "name": "quesarave",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "db:init": "npx wrangler d1 execute quesarave --local --file=./schema.sql",
    "deploy": "astro build && node -e \"const fs=require('fs'); fs.rmSync('dist/server/wrangler.json', {force: true}); fs.rmSync('.wrangler', {recursive: true, force: true});\" && npx wrangler pages deploy"
  },
  "dependencies": {
    "astro": "^6.0.0",
    "@astrojs/cloudflare": "^13.0.0",
    "@astrojs/preact": "^4.0.0",
    "preact": "^10.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "vite": "^7.0.0"
  }
}
